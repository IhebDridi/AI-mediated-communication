PORT=3001
CLIENT_ORIGIN=http://localhost:5173
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Required in production: room creation uses POST /api/admin/rooms with
# Authorization: Bearer <ADMIN_SECRET>. If unset, admin routes are open (dev only).
ADMIN_SECRET=

# Clever Cloud PostgreSQL add-on injects POSTGRESQL_* variables automatically.
# Locally you can use a single URL:
# DATABASE_URL=postgresql://postgres:dev@127.0.0.1:5432/margarita
# On Windows, if 5432 is already used by a local PostgreSQL install, map Docker to 5433:
#   docker run ... -p 5433:5432 ...
#   DATABASE_URL=postgresql://postgres:dev@127.0.0.1:5433/margarita
